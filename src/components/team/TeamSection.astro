---
import { storyblokEditable } from "@storyblok/astro";
import { isBlokValid, getImageUrl, getAltText } from "../../utils/storyblok"
import Tag from "../ui/Tag.astro";
import Heading from "../ui/Heading.astro";

const { blok } = Astro.props;

if (!isBlokValid(blok, "Team Section")) return null;
---

<section id="team-section" {...storyblokEditable(blok)}>
    <div class="header-area">
        <Tag variant="secondary">{blok.tag_text || "Team"}</Tag>
        <Heading variant="secondary">{blok.heading}</Heading>
    </div>

    {blok.departments?.map((dept) => (
        <div class="department-group" {...storyblokEditable(dept)}>
            <div class="dept-header">
                <h3 class="dept-title">{dept.department}</h3>
                <div class="dept-stripe"></div>
            </div>

            <div class="grid-container">
                {dept.members?.map((person) =>{

                    const imageSrc = getImageUrl(person.image, "/m/640x800/smart/filters:format(webp):quality(75)", person.name || "Team Person Image");
                    const altText = getAltText(person.image, person.name || "Person name");

                    const fallbackImage = "/anonymous_person.png";
                    const finalSrc = imageSrc || fallbackImage;
                    return (
                            <div class="card" {...storyblokEditable(person)}>
                                <div class="image-wrapper">
                                    {/* <img src={person.image?.filename || "src/assets/anonymous_person.png"} alt={person.name} loading="lazy" /> */}
                                    {/* <img src={person.image?.filename 
                                                ? `${person.image?.filename}/m/640x800/smart/filters:format(webp):quality(75)` 
                                                : "src/assets/anonymous_person.png"
                                            } 
                                        alt={person.name || "Person name"}
                                        loading="lazy"
                                        width="320" 
                                        height="400"
                                    /> */}
                                   
                                        <img 
                                            src={finalSrc} 
                                            alt={altText}
                                            width="320"
                                            height="400"
                                            loading="lazy"
                                        />
                                    
                                </div>
                                <div class="info">
                                    <div class="name">{person.name}</div>
                                    <div class="job-title">{person.job}</div>
                                </div>
                            </div>
                        )
                    })}
            </div>
        </div>
    ))}
</section>

<style>
    #team-section {
        display: flex;
        flex-direction: column;
        width: 100%;
        padding-block: 80px;
        row-gap: 20px;
        background-color: white;
    }

    .header-area {
        padding-inline: clamp(1.25rem, 8vw, 10%);
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 20px;
    }

    .department-group {
        display: flex;
        flex-direction: column;
        gap: 30px;
    }

    .dept-header {
        padding-inline: clamp(1.25rem, 8vw, 10%);
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .dept-title {
        font-family: "PT Sans", sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: #38322B;
        text-transform: uppercase;
        letter-spacing: 1px;
        white-space: nowrap;
    }

    .dept-stripe {
        height: 1px;
        flex-grow: 1;
        background-color: rgba(163, 141, 117, 0.4); 
    }

    .grid-container {
        display: grid;
        /* MOBILE CHANGE: Switched from 1 column to 2 columns to reduce image size */
        grid-template-columns: repeat(2, 1fr); 
        gap: 15px;
        padding-inline: clamp(1.25rem, 8vw, 10%);
    }

    .card {
        display: flex;
        flex-direction: column;
        /* MOBILE CHANGE: Reduced padding for smaller cards */
        padding: 10px;
        border-radius: 20px;
        background-color: #38322B;
        color: white;
        transition: transform 0.3s ease;
    }

    .image-wrapper {
        width: 100%;
        /* MOBILE CHANGE: Forced square crop for mobile readability */
        aspect-ratio: 1 / 1; 
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 10px;
    }

    img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .info {
        padding: 4px;
        text-align: left;
    }

    .name {
        font-family: "PT Sans", sans-serif;
        /* MOBILE CHANGE: Smaller font to prevent text wrapping in 2-column grid */
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 2px;
    }

    .job-title {
        font-family: "PT Sans", sans-serif;
        /* MOBILE CHANGE: Smaller font to match new card scale */
        font-size: 0.75rem;
        font-weight: 300;
        color: #A38D75;
    }

    /* TABLET & DESKTOP: Restoring your original portrait look */
    @media (min-width: 768px) {
        .grid-container {
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }
        
        .image-wrapper {
            /* Restoring 4/5 ratio for tablet and desktop */
            aspect-ratio: 4 / 5;
        }
        
        .card {
            padding: 12px;
        }
        
        .name {
            font-size: 1.1rem;
        }
        
        .job-title {
            font-size: 0.85rem;
        }
    }

    @media (min-width: 1200px) {
        .grid-container { 
            grid-template-columns: repeat(4, 1fr); 
            gap: 24px; 
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .card:hover img {
            transform: scale(1.05);
        }
    }

    /* MOBILE SPECIFIC: 767px and below */
    @media (max-width: 767px) {
        #team-section {
            padding-block: 40px; /* Tighter vertical spacing */
            padding-bottom: 10px;
        }
        
        /* 15PX RULE: Applied to headers and grids */
        .header-area, .dept-header, .grid-container {
            padding-inline: 15px;
        }
        
        .grid-container {
            gap: 12px; /* Tighter gap between small cards */
        }
    }
</style>
