---
import { storyblokEditable, renderRichText } from "@storyblok/astro";
import Heading from "./ui/Heading.astro";
import Button from "./ui/Button.astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";

const { blok } = Astro.props;
const renderedContent = renderRichText(blok.text);
---
<section id="call-to-action-section" {...storyblokEditable(blok)}>

    <div class="wrapper">
          {blok.img && <img src={blok.img.filename} alt={blok.img.alt}/>}
         <div class="overlay"></div>
        <div class="wrapper-content">
        <div class="heading"> <Heading>{blok.heading}</Heading></div>
                <div class="text" set:html={renderedContent} />
                <div class="btn">
                    <Button variant="quinary" style="padding-inline: 100px;">{blok.button_text}</Button>
                </div>
        </div>
        
    </div>
</section>

<style>
    #call-to-action-section {
        display: flex;
        padding-top: 60px;
        padding-bottom: 60px;
        padding-inline: clamp(1.25rem, 8vw, 10%);
        width: 100%;
        color: white;
    }

    .wrapper {
        display: flex;
        min-height: 500px;
        width: 100%;
        border-radius: 40px;
        background-color: #38322B;
        position: relative; /* CRITICAL: Anchor for the image */
        overflow: hidden;
        justify-content: center;
        align-items: center;
    }

    .wrapper-content {
        position: relative; /* CRITICAL: Forces it above the image */
        z-index: 10;
        display: flex;
        flex-direction: column;
        
        /* UPDATED: max-width keeps the "squished" look on desktop but fits mobile */
        width: 100%;
        max-width: 900px; 
        
        padding: 40px;
        text-align: center;
        row-gap: 10px;
        align-items: center;
        justify-content: center;
        /* Padding inline here helps with the "squish" */
        padding-inline: clamp(1.5rem, 10vw, 15%);
    }

    img {
        position: absolute;
        inset: 0;
        height: 100%;
        width: 100%;
        object-fit: cover;
        /* UPDATED: Ensures the image subject isn't cut off at the top */
        object-position: center; 
        z-index: 1;
    }

    .overlay {
        position: absolute;
        inset: 0;
        background: rgba(56, 50, 43, 0.8);
        z-index: 2;
    }

    .btn {
        height: fit-content;
        width: 100%;
        padding-top: 20px;
    }

    /* Target the button padding responsively */
    .btn :global(button), .btn :global(a) {
        padding-inline: clamp(2rem, 15vw, 100px) !important;
    }

    .text {
        color: white;
        font-size: 1.2rem;
        line-height: 1.6;
    }

    .text :global(*) {
        color: white !important;
    }

    .heading {
        border-bottom: solid 1px #A38D75;
        padding-bottom: 20px;
        margin-bottom: 10px;
    }
</style>
