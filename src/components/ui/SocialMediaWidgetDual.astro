---
import { storyblokEditable } from "@storyblok/astro";
import { isBlokValid, getImageUrl, getAltText, formatLink } from "../../utils/storyblok";

const { blok } = Astro.props;

if (!isBlokValid(blok, "Social Media Section")) return null;

const imageSrc = getImageUrl(blok.image, "/m/800x800/smart/filters:format(webp):quality(75)", "Social Media Image");
const altText = getAltText(blok.image, "Social Media Image");

const igHref = formatLink(blok.instagram_link, "#");
const fbHref = formatLink(blok.facebook_link, "#");

const icons = {
  instagram: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.058-1.69-.072-4.949-.072zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c.796 0 1.441.645 1.441 1.44s-.645 1.44-1.441 1.44c-.795 0-1.44-.645-1.44-1.44s.645-1.44 1.44-1.44z",
  facebook: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
};
---

<div class="post-card" {...storyblokEditable(blok)}>
    <div class="image-wrapper">
        {imageSrc && (
            <img 
                src={imageSrc} 
                alt={altText}
                width="600"
                height="600"
                loading="lazy"
            />
        )}
        <div class="hover-overlay">
            <div class="icon-group">
                {igHref !== "#" && (
                    <a href={igHref} target="_blank" class="social-link" aria-label="Instagram">
                        <svg viewBox="0 0 24 24"><path d={icons.instagram} /></svg>
                    </a>
                )}
                {fbHref !== "#" && (
                    <a href={fbHref} target="_blank" class="social-link" aria-label="Facebook">
                        <svg viewBox="0 0 24 24"><path d={icons.facebook} /></svg>
                    </a>
                )}
            </div>
        </div>
    </div>
</div>

<style>
    .post-card {
        aspect-ratio: 1 / 1;
        border-radius: 20px; 
        overflow: hidden;
        background-color: #38322B;
    }
    .image-wrapper { width: 100%; height: 100%; position: relative; }
    img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
    
    .hover-overlay {
        position: absolute;
        inset: 0;
        background: rgba(163, 141, 117, 0.9);
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(2px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .icon-group { display: flex; gap: 25px; }

    .social-link { 
        color: white; 
        transition: transform 0.3s ease, color 0.3s ease; 
    }
    .social-link:hover { transform: scale(1.1); }
    
    svg { width: 45px; height: 45px; fill: currentColor; }

    @media (hover: hover) {
        .post-card:hover img { transform: scale(1.05); }
        .post-card:hover .hover-overlay { opacity: 1; }
    }
    
    /* Show on mobile tap */
    @media (max-width: 767px) {
        .post-card:active .hover-overlay { opacity: 1; }
    }
</style>