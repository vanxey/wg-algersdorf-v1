---
import { storyblokEditable } from "@storyblok/astro";
import { isBlokValid } from "../../utils/storyblok";
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
const { blok } = Astro.props;

if (!isBlokValid(blok, "Navbar dropdown")) return null;
---

<div class="dropdown" {...storyblokEditable(blok)}>
    <button class="dropdown-trigger">
        {blok.label}
        <svg class="chevron" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
            <path d="M5.22 8.22L10 13l4.78-4.78" />
        </svg>
    </button>
    <div class="dropdown-content">
        {blok.sub_links?.map((link) => (
            <StoryblokComponent blok={link} />
        ))}
    </div>
</div>

