---
const { variant = 'primary' } = Astro.props;
---
<div id="tag">
    <div class=`tag-wrapper ${variant}`>
        <slot/>
    </div>
</div>


<style>
    #tag{
        display: flex;
        width: auto;
    }
     .tag-wrapper{
        font-family: "PT Sans", sans-serif;
        font-style: italic;
        /* font-size: large;
        padding: 5px 10px 5px 10px; */
        font-size: clamp(1rem, 1.5vw, 1.25rem);
        
        padding: clamp(3px, 0.8vw, 5px) clamp(8px, 1.5vw, 12px);
        
        display: inline-block;
        line-height: 1.2;
    }
    .primary{background-color: white; color: #38322B;}
    .secondary{background-color: #38322B; color: white;}
</style>