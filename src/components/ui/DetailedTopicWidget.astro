---
import { storyblokEditable } from "@storyblok/astro";

const { blok } = Astro.props;
---
<section id="detailed-topic-widget" {...storyblokEditable(blok)}>
    <div class="widget">
        <div class="row">
            <div class="heading">{blok.heading}</div>
            <div class="image"><img src={blok.img?.filename} alt={blok.img?.alt} /></div>
        </div>
        
        <div class="text">{blok.text}</div>
    </div>
</section> 

<style>
    #detailed-topic-widget {
        display: flex;
       
        height: auto; 
        min-height: 350px;
        
        
        width: 100%;
        max-width: 400px; 
        
        background-color: #38322B;
        border-radius: 30px;
        padding: clamp(20px, 5vw, 30px); 
        color: white;
        transition: transform 0.3s ease;
    }

    
    /* @media (hover: hover) {
        #detailed-topic-widget:hover {
            transform: translateY(-5px);
        }
    } */

    .widget {
        display: flex;
        flex-direction: column;
        width: 100%;
        row-gap: 20px;
    }

    .row {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        justify-content: space-between;
        gap: 15px;
    }

    .heading {
        font-family: "PT Sans Caption", sans-serif;
        font-weight: 600;
        
        font-size: clamp(1.5rem, 4vw, 2rem); 
        line-height: 1.2;
    }

    .text {
        font-family: "PT Sans", sans-serif;
        font-weight: 400;
        
        font-size: clamp(1rem, 2.5vw, 1.2rem); 
        line-height: 1.5;
        opacity: 0.9;
    }

    .image{
        height: clamp(60px, 10vw, 80px);
        width: clamp(60px, 10vw, 80px);
        flex-shrink: 0; 
        border-radius: 15px;
        overflow: hidden;
    }
    
    img {
        height: 100%;
        width: 100%;
        object-fit: cover;
    }

    /* @media (max-width: 480px) {
        #detailed-topic-widget {
            min-height: 300px;
        }
    } */
</style>
