---
import { storyblokEditable } from "@storyblok/astro";
import { isBlokValid, getImageUrl, getAltText } from "../../utils/storyblok"

const { blok } = Astro.props;

if (!isBlokValid(blok, "Detailed Topic Widget")) return null;

const imageSrc = getImageUrl(blok.img, "/m/240x240/smart/filters:format(webp):quality(70)", "Topic Widget Image");
const altText = getAltText(blok.img, "Topic Widget Image");
---
<section id="detailed-topic-widget" {...storyblokEditable(blok)}>
    <span id={blok.id}>
    <div class="widget">
        <div class="row">
            <div class="heading">{blok.heading}</div>
            <div class="image">
                <!-- <img src={blok.img?.filename} alt={blok.img?.alt} /> -->
                 <!-- <img src={`${blok.img?.filename}/m/240x240/smart/filters:format(webp):quality(70)`} 
                    alt={blok.img.alt || "Detailed Topic Widget"}
                    loading="lazy"
                    width="120" 
                    height="120"
            /> -->
             {imageSrc && (
                <img 
                    src={imageSrc} 
                    alt={altText}
                    width="120"
                    height="120"
                    loading="lazy"
                />
            )}
            </div>
        </div>
        
        <div class="text">{blok.text}</div>
    </div>
    </span>
</section> 

<style>
    #detailed-topic-widget {
        display: flex;
       
        height: auto; 
        min-height: 350px;
        
        
        width: 100%;
        max-width: 400px; 
        
        background-color: #38322B;
        border-radius: 30px;
        padding: clamp(20px, 5vw, 30px); 
        color: white;
        transition: transform 0.3s ease;
    }

    
    /* @media (hover: hover) {
        #detailed-topic-widget:hover {
            transform: translateY(-5px);
        }
    } */

    .widget {
        display: flex;
        flex-direction: column;
        width: 100%;
        row-gap: 20px;
    }

    .row {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        justify-content: space-between;
        gap: 15px;
    }

    .heading {
        font-family: "PT Sans Caption", sans-serif;
        font-weight: 600;
        
        font-size: clamp(1.5rem, 4vw, 2rem); 
        line-height: 1.2;
    }

    .text {
        font-family: "PT Sans", sans-serif;
        font-weight: 400;
        
        font-size: clamp(1rem, 2.5vw, 1.2rem); 
        line-height: 1.5;
        opacity: 0.9;
    }

    .image{
        height: clamp(60px, 10vw, 80px);
        width: clamp(60px, 10vw, 80px);
        flex-shrink: 0; 
        border-radius: 15px;
        overflow: hidden;
    }
    
    img {
        height: 100%;
        width: 100%;
        object-fit: cover;
    }

    /* @media (max-width: 480px) {
        #detailed-topic-widget {
            min-height: 300px;
        }
    } */

    /* --- Mobile Compatibility --- */
    @media (max-width: 767px) {
        #detailed-topic-widget {
            max-width: none; 
            width: 100%;
            
            min-height: auto; 
        }

        .row {
            gap: 20px;
        }

        .image {
            height: 80px;
            width: 80px;
        }
    }

</style>
