---
import { storyblokEditable } from "@storyblok/astro"
 
const { blok } = Astro.props
---

<div id="navbar" {...storyblokEditable(blok)}>
    <div id="logo-container">
        <a id="logo" href="/home" aria-label="Zur Startseite">
             <img src="src/assets/wg-logo-2.png" alt="logo" height="auto" width="auto"/>
        </a>
    </div>
    
    <nav id="nav-menu">
        <a href="/home">Home</a>
        <a href="/about-us">Über uns</a>
        
        <div class="dropdown">
            <button class="dropdown-trigger">
                Die WG
                <svg class="chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                </svg>
            </button>
            <div class="dropdown-content">
                <a href="/team">Das Team</a>
                <a href="/bewohner">Die Community</a>
            </div>
        </div>
        <a href="/about-us#contact-section">Kontakt</a>
    </nav>

    <div id="burger-menu" aria-label="Toggle Menu">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#000000">
            <path fill-rule="evenodd" d="M3 6.75A.75.75 0 0 1 3.75 6h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 6.75ZM3 12a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 12Zm0 5.25a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd"/>
        </svg>
    </div>
</div>

<script>
    const burgerMenu = document.getElementById('burger-menu');
    const navMenu = document.getElementById('nav-menu');

    burgerMenu?.addEventListener('click', () => {
        const isActive = navMenu?.classList.toggle('active');
        burgerMenu.setAttribute('aria-expanded', isActive ? 'true' : 'false');
    });

    const navLinks = document.querySelectorAll('#nav-menu a');
    navLinks.forEach(link => {
        link.addEventListener('click', () => {
            navMenu?.classList.remove('active');
        });
    });
</script>

<style>
    #navbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 50px;
        height: 88px;
        width: 100%;
        background-color: white;
        font-family: 'Inter', sans-serif;
        font-weight: 700;
        position: sticky;
        top: 0;
        z-index: 1000; 
        border-bottom: 1px solid #f0f0f0;
    }

    #logo { display: flex; height: 70px; width: 70px; }
    #logo img { width: 100%; height: auto; object-fit: contain; }

    nav {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: end;
        column-gap: 30px;
        height: 100%;
    }

    nav a, .dropdown-trigger {
        text-decoration: none;
        color: black;
        font-family: 'Inter', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: color 0.3s ease;
    }

    nav a:hover, .dropdown-trigger:hover { color: #A38D75; }

    .dropdown {
        position: relative;
        height: 100%;
        display: flex;
        align-items: center;
    }

    .dropdown-content {
        position: absolute;
        top: 80%;
        left: 50%;
        transform: translateX(-50%);
        background-color: white;
        min-width: 160px;
        box-shadow: 0px 8px 16px rgba(0,0,0,0.1);
        border-radius: 8px;
        padding: 10px 0;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        z-index: 1001;
    }

    .dropdown:hover .dropdown-content {
        opacity: 1;
        visibility: visible;
        top: 100%;
    }

    .dropdown-content a {
        padding: 12px 20px;
        display: block;
        font-size: 0.9rem;
        border-bottom: none;
    }

    .chevron { width: 18px; height: 18px; transition: transform 0.3s; }
    .dropdown:hover .chevron { transform: rotate(180deg); }

    #burger-menu { display: none; cursor: pointer; }
    #burger-menu svg { height: 40px; width: 40px; }

    @media screen and (max-width: 640px) {
        #navbar { padding: 0 20px; }
        #burger-menu { display: flex; }

        nav {
            position: absolute;
            top: 100%; left: 0; width: 100%;
            background-color: white;
            flex-direction: column;
            height: auto; 
            padding: 0;
            z-index: 999; 
            overflow: hidden;
            max-height: 0; opacity: 0;
            transition: max-height 0.4s ease-in-out, opacity 0.3s ease;
            box-shadow: 0 10px 15px rgba(0,0,0,0.1);
            pointer-events: none;
        }

        nav.active { max-height: 800px; opacity: 1; pointer-events: auto; }

        .dropdown {
            width: 100%;
            flex-direction: column;
            height: auto;
        }

        .dropdown-trigger {
            width: 100%;
            height: 70px;
            justify-content: center;
            border-bottom: 1px solid #f0f0f0;
        }

        .dropdown-content {
            position: static;
            transform: none;
            width: 100%;
            box-shadow: none;
            opacity: 1;
            visibility: visible;
            display: flex;
            flex-direction: column;
            background-color: #f9f9f9;
            padding: 0;
        }

        nav a, .dropdown-content a {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 70px;
            border-bottom: 1px solid #f0f0f0;
        }

        nav.active a { opacity: 1; }
    }
</style>

