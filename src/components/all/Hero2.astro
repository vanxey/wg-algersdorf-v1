---
import { storyblokEditable } from "@storyblok/astro"
import { formatLink } from "../../utils/storyblok";
import Button2 from "../ui/Button2.astro";


const { blok } = Astro.props;
const href = formatLink(blok.link);
---

<section id="hero2" {...storyblokEditable(blok)}>
    <div class="wrapper">
        <div class="col-1">
            <div class="heading">{blok.heading}</div>
            <Button2 variant="hero" href={href}>{blok.button_text}</Button2>
        </div>
        <div class="col-2">
            <div class="img-wrapper">
              {blok.img && <img src={blok.img.filename} alt={blok.img.alt}/>}
            </div>
        </div>
    </div>
</section>

<style>
    #hero2 {
        display: flex;
        height: auto;
        min-height: 40vh;
        width: 100%; 
        padding: 20px;
        color: white;
    }

    .wrapper {
        display: grid;
        grid-template-columns: 1fr;
        width: 100%;
        background-color: #38322B;
        border-radius: 30px;
        overflow: hidden;
        position: relative;
        z-index: 1;
    }

    .col-1 {
        display: flex;
        flex-direction: column;
        padding: 60px 30px;
        align-items: center;
        text-align: center;
        z-index: 2; 
    }

    .heading {
        font-family: 'Alexandria', sans-serif;
        font-weight: 700;
        font-size: clamp(1.8rem, 6vw, 3.8rem);
        line-height: 1.1;
        padding-bottom: 20px;
    }

    .col-2 {
        display: flex;
        padding: 0; 
    }

    .img-wrapper {
        width: 100%;
        height: 100%;
        overflow: hidden;
        box-shadow: none; 
    }

    img {
        height: 100%;
        width: 100%;
        object-fit: cover;
    }

    @media (min-width: 1024px) {
        .wrapper {
            grid-template-columns: 1fr 1fr;
            align-items: center;
        }

        .col-1 {
            padding: 60px;
            align-items: flex-start;
            text-align: left;
        }

        .col-2 {
            padding: 30px;
        }

        .img-wrapper {
            aspect-ratio: 4 / 3;
            border-radius: 30px;
            box-shadow: 0px 8px 25px rgba(0, 0, 0, 0.3); /* Professional subtle shadow */
        }
    }

    @media (max-width: 1023px) {
        .col-2 {
            position: absolute;
            inset: 0;
            z-index: 0;
            opacity: 0.6;
        }

        .wrapper::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                to bottom,
                rgba(56, 50, 43, 0.8) 0%,
                rgba(56, 50, 43, 0.4) 100%
            );
            z-index: 1;
        }

        .col-1 {
            min-height: 400px; 
            justify-content: center;
        }
    }
</style>

