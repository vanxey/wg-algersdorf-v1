---
import { storyblokEditable } from "@storyblok/astro"
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import { isBlokValid, getImageUrl } from "../../utils/storyblok";

const { blok } = Astro.props;

if (!isBlokValid(blok, "Navbar")) return null;

const logoSrc = getImageUrl(blok.logo, "", "Navbar Logo");

const localLogo = "/wg-logo-2.png";
const finalLogo = logoSrc || localLogo;
---

<div id="navbar" {...storyblokEditable(blok)}>
    <div id="logo-container">
        <a id="logo" href="/home" aria-label="Zur Startseite">
             <img src={finalLogo} alt="logo" height="auto" width="auto"/>
        </a>
    </div>
    
    <nav id="nav-menu">
        {blok.nav_items?.map((nestedBlok) => (
            <StoryblokComponent blok={nestedBlok} />
        ))}
    </nav>

    <div id="burger-menu" aria-label="Toggle Menu">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#000000">
            <path fill-rule="evenodd" d="M3 6.75A.75.75 0 0 1 3.75 6h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 6.75ZM3 12a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 12Zm0 5.25a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd"/>
        </svg>
    </div>
</div>

