---
import Button from "../ui/Button.astro";
import Tag from "../ui/Tag.astro";
import { storyblokEditable } from "@storyblok/astro";
import { isBlokValid, getImageUrl, getAltText, formatLink } from "../../utils/storyblok"

const { blok } = Astro.props;

if (!isBlokValid(blok, "SliderArea")) return null;

const img1 = getImageUrl(blok.img_1, "/m/800x800/smart/filters:format(webp):quality(75)", "Slider Img 1");
const img2 = getImageUrl(blok.img_2, "/m/800x800/smart/filters:format(webp):quality(75)", "Slider Img 2");
const img3 = getImageUrl(blok.img_3, "/m/800x800/smart/filters:format(webp):quality(75)", "Slider Img 3");

const alt1 = getAltText(blok.img_1, blok.img_1_title);
const alt2 = getAltText(blok.img_2, blok.img_2_title);
const alt3 = getAltText(blok.img_3, blok.img_3_title);

const href = formatLink(blok.link, "Slider Button");
---

<section {...storyblokEditable(blok)} id="slider-area">
    <div id="slider-tag">
        <div class="tag-wrapper">
            <Tag variant="primary">{blok.category_text}</Tag>
        </div>
    </div>
    
    <div id="slider-heading">
        <div class="heading">{blok.heading}</div>
        <Button href={href} variant="tertiary">{blok.button_text}</Button>
    </div>
    
    <div id="slider-content">
        <div class="slider-column">
            <div class="img-container">
                <!-- {blok.img_1 && <img src={blok.img_1.filename} alt={blok.img_1.alt}/>} -->
                 <!-- {blok.img_1?.filename && (
                    <img 
                        src={`${blok.img_1?.filename}/m/800x800/smart/filters:format(webp):quality(75)`} 
                        alt={blok.img_1.alt || ""} 
                        loading="lazy"
                        width="400"
                        height="400"
                        decoding="async"
                    />
                )} -->
                {img1 && (
                    <img 
                        src={img1} 
                        alt={alt1} 
                        loading="lazy"
                        width="400"
                        height="400"
                        decoding="async"
                    />
                )}
                <div class="img-text-wrapper">
                    <div class="img-title">{blok.img_1_title}</div>
                    <div class="img-description">{blok.img_1_description}</div>
                </div>
            </div>
        </div>

        <div class="slider-column">
            <div class="img-container">
                <!-- {blok.img_2 && <img src={blok.img_2.filename} alt={blok.img_2.alt}/>} -->
                 <!-- {blok.img_2?.filename && (
                <img 
                    src={`${blok.img_2?.filename}/m/800x800/smart/filters:format(webp):quality(75)`} 
                    alt={blok.img_2.alt || ""} 
                    loading="lazy"
                    width="400"
                    height="400"
                    decoding="async"
                />
            )} -->
            {img2 && (
                <img 
                    src={img2} 
                    alt={alt2} 
                    loading="lazy"
                    width="400"
                    height="400"
                    decoding="async"
                />
            )}
                <div class="img-text-wrapper">
                    <div class="img-title">{blok.img_2_title}</div>
                    <div class="img-description">{blok.img_2_description}</div>
                </div>
            </div>
        </div>

        <div class="slider-column">
            <div class="img-container">
                <!-- {blok.img_3 && <img src={blok.img_3.filename} alt={blok.img_3.alt}/>} -->
                 <!-- {blok.img_3?.filename && (
                    <img 
                        src={`${blok.img_3?.filename}/m/800x800/smart/filters:format(webp):quality(75)`} 
                        alt={blok.img_3.alt || ""} 
                        loading="lazy"
                        width="400"
                        height="400"
                        decoding="async"
                    />
                )} -->
                {img3 && (
                    <img 
                        src={img3} 
                        alt={alt3} 
                        loading="lazy"
                        width="400"
                        height="400"
                        decoding="async"
                    />
                )}
                <div class="img-text-wrapper">
                    <div class="img-title">{blok.img_3_title}</div>
                    <div class="img-description">{blok.img_3_description}</div>
                </div>
            </div>
        </div>
    </div>

    <div id="slider-indicator">
        <span class="dot active"></span>
        <span class="dot"></span>
        <span class="dot"></span>
    </div>
</section>
<script>
    const slider = document.getElementById('slider-content');
    const dots = document.querySelectorAll('.dot');
    const slides = document.querySelectorAll('.slider-column');

    if (slider && slides.length > 0) {
        const getCenterTarget = (index: number) => {
            const targetSlide = slides[index] as HTMLElement;
            return targetSlide.offsetLeft - (slider.clientWidth / 2) + (targetSlide.clientWidth / 2);
        };

        if (slides.length >= 2) {
            slider.scrollLeft = getCenterTarget(1);
        }

        dots.forEach((dot, index) => {
            dot.addEventListener('click', () => {
                slider.scrollTo({
                    left: getCenterTarget(index),
                    behavior: 'smooth'
                });
            });
        });

        slider.addEventListener('scroll', () => {
            const scrollLeft = slider.scrollLeft;
            const firstSlide = slider.querySelector('.slider-column') as HTMLElement;
            
            if (firstSlide) {
                const slideWidth = firstSlide.clientWidth;
                const gap = 20; 
                const index = Math.round(scrollLeft / (slideWidth + gap));
                
                dots.forEach((dot, i) => {
                    dot.classList.toggle('active', i === index);
                });
            }
        });
    }
</script>

