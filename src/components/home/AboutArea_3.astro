---
import Button from "../ui/Button.astro"
import Tag from "../ui/Tag.astro"
import { storyblokEditable } from "@storyblok/astro"
import { isBlokValid, renderSafeRichText, getImageUrl, getAltText } from "../../utils/storyblok"

const { blok } = Astro.props

if (!isBlokValid(blok, "About Area 3")) return null;

const renderedContent1 = renderSafeRichText(blok.text_1, "About Text");
const renderedContent2 = renderSafeRichText(blok.text_2, "About Text");
const imageSrc = getImageUrl(blok.img_1, "/m/1200x0/filters:format(webp):quality(80)", "About Image");
const altText = getAltText(blok.img_1, "About Us Image");
---

<section id="about-area" {...storyblokEditable(blok)}>
    <div class="about-row">
        <div class="about-content">
            <div class="about-heading">{blok.heading_1}</div>
            <div class="about-subheading">{blok.subheading_1}</div>
            <div class="about-text" set:html={renderedContent1}/>
            <div class="about-text" set:html={renderedContent2}/>
        </div>
        <div class="img-container">
            <!-- {blok.img_1 && <img src={blok.img_1.filename} alt={blok.img_1.alt}/>} -->
             <!-- {blok.img_1?.filename && (
            <img 
                src={`${blok.img_1?.filename}/m/1200x900/smart/filters:format(webp):quality(75)`} 
                alt={blok.img_1.alt || "About Image"}
                width="600" 
                height="450" 
                loading="lazy"
                decoding="async"
            />
        )} -->
        {imageSrc && (
                <img 
                    src={imageSrc} 
                    alt={altText}
                    width="1200"
                    height="600"
                    loading="lazy"
                    decoding="async"
                />
            )}
        </div>
    </div>
    <!-- <div class="about-row2"><div class="about-text" set:html={renderedContent2}/></div> -->
    
</section>
 <style>
    #about-area {
        display: flex;
        flex-direction: column;
        height: auto;
        width: 100%;

        padding-inline: clamp(1.25rem, 8vw, 10%);
        padding-top: 60px;
        padding-bottom: 60px;

        background-color: #38322B;
        color: #FDFBF7;
        /* background-color: #FDFBF7;
        color: #222222; */
    }

    .about-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 40px; 
        width: 100%;
        align-items: center;
    }

    @media screen and (min-width: 1024px) {
        .about-row {
            grid-template-columns: 60% 1fr;
            column-gap: 40px;
            align-items: stretch;
        }
    }

    .about-content {
        display: flex; 
        justify-content: center;
        flex-direction: column;
    }

    @media screen and (min-width: 1024px) {
        .about-content {
            display: flex;
            flex-direction: column;
        }
    }

    .about-heading {
        font-family: "PT Sans Caption", sans-serif;
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        font-weight: bold;
        line-height: 1.1;
        order: 1;

        display: flex;
        align-items: stretch; 
        gap: 20px;  
    }

    .about-heading::before {
        content: "";
        display: inline-block;
        width: 4px;   
        background-color: currentColor; 
        flex-shrink: 0;     
        border-radius: 2px;   
    }

    .about-subheading {
        font-family: "PT Sans", sans-serif;
        font-size: 1.1rem;
        font-style: italic;
        /* font-weight: bold; */
        /* color: #38322B; */
        color: #FDFBF7;
        opacity: 1;
        padding-top: 5px;
        order: 2;
        margin: 1.2rem 0px 1.2rem;
    }

    .img-container {
        display: flex;
        width: 100%;
        aspect-ratio: 4 / 3;
        overflow: hidden;
        border-radius: 30px;
        box-shadow: 0px 4px 16px 2px #222222;
        
        order: 3;
    }

    @media screen and (min-width: 1024px) {
        .img-container {
            order: unset; 

            align-self: stretch;
            border-radius: 20px;

            height: 100%;
            width: 100%;
        }
    }

    .about-text {
        display: block; 
        font-family: "PT Sans", sans-serif;
        font-size: 1.1rem;
        line-height: 1.6;
        /* color: #38322B; */
         color: #FDFBF7;
         /* color: #222222; */
        
        order: 4;
    }

    .about-text :global(p) {
        margin-bottom: 1.2rem;
    }

    .about-text :global(span) {
        color: #FDFBF7 !important;
        /* color: #222222 !important; */
    }

    img {
        height: 100%;
        width: 100%;
        object-fit: cover;
        object-position: top;
    }
</style>