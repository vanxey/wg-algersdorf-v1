---
import Button from "../ui/Button.astro";
import { storyblokEditable } from '@storyblok/astro';
import { isBlokValid, formatLink, getImageUrl, getAltText } from "../../utils/storyblok";

const { blok } = Astro.props;

if (!isBlokValid(blok, "Hero")) return null;

const mainHref = formatLink(blok.link, "Mehr erfahren");
const href1 = formatLink(blok.link_1, "Community living");
const href2 = formatLink(blok.link_2, "Gain back independence");
const href3 = formatLink(blok.link_3, "Trust the process");

// const mobileImgUrl = blok.image_mobile || blok.image;
const desktopImg = getImageUrl(blok.image, "/m/1800x0/filters:format(webp):quality(80)", "Desktop Hero Image");
const mobileImg = getImageUrl(blok.image_mobile || blok.image, "/m/1000x1500/smart/filters:format(webp):quality(80)", "Mobile Hero Image");

const altText = getAltText(blok.image, blok.title_2);
---

<section {...storyblokEditable(blok)} id="hero">
    <div class="hero-section-1">
        <div class="hero-h1">{blok.title_1}</div>
        <div class="hero-h2">{blok.title_2}</div>
        <div class="btn-desktop">
            <Button href={mainHref} variant="hero">{blok.button_text}</Button>
        </div>
    </div>
    
    <div class="hero-section-2">
        <div class="hero-img">
            <picture>
                <source media="(max-width: 1099px)" srcset={desktopImg} />
                <!-- <img src={blok.image} alt="Hero Image" /> -->
                <!-- src={`${blok.image}/m/1800x0/filters:format(webp):quality(80)`}  -->
                <img 
                    src={desktopImg} 
                    alt={altText} 
                    loading="eager" 
                    fetchpriority="high" 
                    decoding="sync"
                />
            </picture>
        </div>

        <div class="hero-img-mobile">
            <picture>
                <source media="(max-width: 1099px)" srcset={mobileImg} />
                <!-- <img src={blok.image} alt="Hero Image" /> -->
                <!-- src={`${blok.image_mobile}/m/1000x1500/smart/filters:format(webp):quality(80)`} -->
                <img 
                    src={mobileImg}
                    alt={altText} 
                    loading="eager" 
                    fetchpriority="high" 
                    decoding="sync"
                />
            </picture>
        </div>

        <div class="hero-links">
            <a href={href1}>{blok.link_1_text}</a>
            <a href={href2}>{blok.link_2_text}</a>
            <a href={href3}>{blok.link_3_text}</a>
        </div>
    </div>
</section>

<style define:vars={{ mobileImgUrl: `url(${mobileImg})` }}>
    #hero {
        display: flex;
        flex-direction: row; 
        width: 100%;
        min-height: 50vh;
        background-color: transparent; 
        overflow: hidden; 
    }

  
    .hero-section-1 {
        display: flex;
        flex-direction: column;

        color: white;
        padding-inline: 20px;

        text-align: center;
        align-items: center;
        justify-content: center;

        border-bottom-left-radius: 40px;
        width: 100%;
        gap: 10px;
        
        background-size: cover;
        background-position: center;
        background-color: #38322B;
    }

    .hero-h1 {
        font-family: 'Alexandria', sans-serif;
        font-weight: 300;
        font-size: clamp(1.1rem, 2vw, 1.8rem);
    }

    .hero-h2 {
        font-family: 'Alexandria', sans-serif;
        font-weight: 700;
        font-size: clamp(2.2rem, 5vw, 4.3rem);
        line-height: 1.1;
        padding-bottom: 20px;
    }

    .hero-section-2 {
        display: flex;
        flex-direction: column;
        
        width: 100%;
        flex-grow: 1;
        border-bottom-right-radius: 40px;

        background-size: cover;
        background-position: center;
        background-color: #A38D75;
    }

    .hero-img-mobile{
        width: 100%;
        height: 100%;
        overflow: hidden; 
    }

    .hero-img-mobile img {
        width: 100%;
        height: 100%;
        border-bottom-right-radius: 40px; 
        object-fit: cover;
        object-position: center;
        display: block;
    }

    .hero-img {
        width: 100%;
        height: 400px;
        overflow: hidden;
        padding-top: 15px;
        display: none;
    }

    .hero-links{
        display: none;
    }

    @media screen and (max-width: 620px) {
        #hero {
            min-height: 70vh; 
        }

        .hero-section-1 {
            background-image: 
                linear-gradient(rgba(56, 50, 43, 0.75), rgba(56, 50, 43, 0.75)), 
                var(--mobileImgUrl);
            
           
            z-index: 1;
            border-bottom-right-radius: 40px; 
        }

        .hero-section-2 {
            display: none;
        }
    }

    
    @media screen and (min-width: 621px) and (max-width: 1099px) {
        .hero-section-2 {
            
            background-image: 
                linear-gradient(rgba(56, 50, 43, 0.5), rgba(56, 50, 43, 0.5)), 
                var(--mobileImgUrl);
            background-size: cover;
            background-position: center;

           
            min-height: 400px; 
            width: 100%;
            
            border-bottom-right-radius: 40px;
        }

        
        .hero-section-2 .hero-img, 
        .hero-section-2 .hero-img-mobile {
            display: none;
        }
    }

    
    @media screen and (min-width: 1100px) {
        #hero {
            display: grid;
            min-height: 60vh;
            grid-template-columns: 40vw 1fr;
            border-bottom-left-radius: 40px;
            border-bottom-right-radius: 40px;
        }

        .hero-section-1 {
            background-image: none; 
            background-color: #38322B;
            margin: 0;
            width: 100%;
            height: 100%;
            border-radius: 0;
            padding: 0 40px;
            gap: 20px;
        }

        .hero-section-2 {
            display: flex;
            border-bottom-right-radius: 0;
        }

        .hero-img-mobile { display: none; }

        .hero-img {
            width: 100%;
            height: 100%;
            overflow: hidden;
            display: flex;
            align-items: start;
            padding-top: 0px;
            padding-left: 10px;
        }

        .hero-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            display: block;
        }

        .hero-links {
            display: flex;
            flex-direction: row;
            justify-content: space-evenly;
            
            align-items: center;
            /* gap: 50px; */
            padding: 50px;
            
        }

        .hero-links a {
            font-family: "PT Sans", sans-serif;
            text-decoration: none;
            color: white;
            font-size: 1.2rem;
            position: relative;
        }

        .hero-links a::after {
            content: '';
            position: absolute;
            width: 0; height: 2px;
            bottom: -5px; left: 50%;
            background: #38322B;
            transition: 0.3s;
            transform: translateX(-50%);
        }
        .hero-links a:hover::after { width: 100%; }
        .hero-links a:hover { color: #38322B; }
    }
</style>