---
import { useStoryblokApi } from "@storyblok/astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import Layout from "../layouts/Layout_static_colors.astro";

export async function getStaticPaths() {
  const storyblokApi = useStoryblokApi();
  const { data } = await storyblokApi.get("cdn/links/", {
    version: "draft",
  });

  const links = data.links;

  return Object.keys(links).flatMap((linkKey) => {
    const slug = links[linkKey].slug;

    if (slug === 'home') {
      return [
        { params: { slug: undefined } }, 
        { params: { slug: 'home' } }    
      ];
    }

    return {
      params: { slug }
    };
  });
}

const { slug } = Astro.params;
const storyblokApi = useStoryblokApi()

let storyPath = slug === undefined ? 'home' : slug;
storyPath = storyPath.replace(/\/$/, "").replace(/\.html$/, "");

const isPreview = import.meta.env.STORYBLOK_IS_PREVIEW === 'true' || import.meta.env.DEV;
const version = isPreview ? "draft" : "published";

// const { data } = await storyblokApi.get(`cdn/stories/${storyPath}`, {
//   version: version,
// });

// const story = data.story;
try {
  const { data } = await storyblokApi.get(`cdn/stories/${storyPath}`, {
    version: version,
  });
  var story = data.story;
} catch (e) {

  console.error(`Storyblok 404: Could not find story with slug "${storyPath}"`);
  throw e; 
}
---

<Layout blok={story.content}>
  <StoryblokComponent blok={story.content} />
</Layout>
